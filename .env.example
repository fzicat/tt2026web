# Supabase Configuration
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_KEY=<service-role-key>
SUPABASE_ANON_KEY=<anon-key>

# IBKR Flex Query Configuration
IBKR_TOKEN=your_ibkr_token
QUERY_ID_DAILY=your_daily_query_id
QUERY_ID_WEEKLY=your_weekly_query_id

# IB Gateway API Configuration
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=7497
IB_GATEWAY_CLIENT_ID=1919
IB_GATEWAY_TIMEOUT=5
IB_GATEWAY_READ_ONLY=true